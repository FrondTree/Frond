# Database (Prisma — local dev; Go API uses same Postgres via pgx)
DATABASE_URL=postgres://frond:frond@localhost:5433/frond?sslmode=disable

# Demo login (seeded via `pnpm db:seed`): username `demo`, password `demo`

# Go API
API_PORT=8080
API_BASE_URL=http://localhost:8080
JWT_SECRET=change-me-to-a-long-random-string-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Google OAuth (dashboard + CLI login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback

# GitHub OAuth (Phase 2 — repo intelligence)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=

# Storage (local dev uses filesystem; production uses R2/S3)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/artifacts
STORAGE_PUBLIC_URL=http://localhost:8080/artifacts

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=frond-dev-master-key

# Next.js Web (dashboard + landing)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string-in-production

# Docs hosting
# Path-based local URL base (fallback when DOCS_HOSTED_DOMAIN is unset)
DOCS_PUBLIC_URL=http://localhost:3001
# Company subdomains: https://{company}.frond.dev/{project}
DOCS_HOSTED_DOMAIN=frond.dev
DOCS_PUBLIC_SCHEME=https
DOCS_BASE_DOMAIN=frond.dev

# Next.js Docs renderer
DOCS_API_URL=http://localhost:8080
NEXT_PUBLIC_DOCS_BASE_DOMAIN=frond.dev
